// src/ictl.pest
WHITESPACE = _{ " " | "\t" | "\r" | "\n" | COMMENT }
COMMENT    = _{ "//" ~ (!"\n" ~ ANY)* | "#" ~ (!"\n" ~ ANY)* }

program = { SOI ~ timeline_block+ ~ EOI }

timeline_block = { "@" ~ time_coord ~ ":" ~ statement_block }

time_coord     = { relative_time | absolute_time | branch_name }
absolute_time  = @{ ASCII_DIGIT+ ~ "ms" }
relative_time  = @{ "+" ~ ASCII_DIGIT+ ~ "ms" }
branch_name    = { identifier }

statement_block = { "{" ~ statement* ~ "}" | statement }

statement = {
    isolate_stmt
    | split_stmt
    | routine_stmt
    | merge_stmt
    | split_map_stmt
    | for_stmt
    | inspect_stmt
    | print_stmt
    | debug_stmt
    | anchor_stmt
    | rewind_stmt
    | commit_stmt
    | speculate_stmt
    | collapse_stmt
    | speculation_mode_stmt
    | select_stmt
    | match_entropy_stmt
    | await_stmt
    | if_stmt
    | break_stmt
    | loop_stmt
    | yield_stmt
    | type_decl
    | decay_handler_stmt
    | assert_time_stmt
    | assignment_stmt
    | open_chan_stmt
    | chan_send_stmt
    | require_decl
    | timeline_block
    | watchdog_stmt
    | reset_stmt
    | network_request_stmt
    | entangle_stmt
    | field_update_stmt
}

entangle_stmt = { "entangle" ~ "(" ~ identifier_list ~ ")" }

decay_handler_stmt = { "decay_handler" ~ "for" ~ identifier ~ "{" ~ statement* ~ "}" }

assert_time_stmt = { "assert_time" ~ "(" ~ "elapsed" ~ relop ~ amount ~ "ms" ~ ")" ~ ("else" ~ statement_block)? }

print_stmt = { "print" ~ "(" ~ expression ~ ")" }

speculate_stmt = { "speculate" ~ "(" ~ "max" ~ amount ~ "ms" ~ ")" ~ "{" ~ statement* ~ "}" ~ fallback_stmt? }
fallback_stmt = { "fallback" ~ "{" ~ statement* ~ "}" }
collapse_stmt = { "collapse" }
speculation_mode_stmt = { "speculation_mode" ~ "(" ~ speculation_mode_value ~ ")" }
speculation_mode_value = { "selective" | "full" }
routine_stmt = { "routine" ~ identifier ~ "(" ~ param_decl_list? ~ ")" ~ return_annotation? ~ "taking" ~ (amount ~ "ms" | "_") ~ "{" ~ statement* ~ "}" }
param_decl_list = { param_decl ~ ("," ~ param_decl)* }
param_decl = { param_mode ~ identifier ~ type_annotation? }
param_mode = { "consume" | "clone" | "decay" | "peek" }
return_annotation = { "->" ~ type_name }

select_stmt = { "select" ~ "(" ~ "max" ~ amount ~ "ms" ~ ")" ~ "{" ~ select_case* ~ timeout_clause? ~ "}" ~ reconcile_clause? }
select_case = { "case" ~ identifier ~ "=" ~ expression ~ ":" ~ statement_block }
timeout_clause = { "timeout" ~ ":" ~ statement_block }

match_entropy_stmt = { "match" ~ "entropy" ~ "(" ~ expression ~ ")" ~ "{" ~ entropy_branch* ~ "}" }
entropy_branch = { "Valid" ~ "(" ~ identifier ~ ")" ~ ":" ~ statement_block | "Decayed" ~ "(" ~ identifier ~ ")" ~ ":" ~ statement_block | "Pending" ~ "(" ~ identifier ~ ")" ~ ":" ~ statement_block | "Consumed" ~ ":" ~ statement_block }

break_stmt = { "break" }

for_mode = { "consume" | "clone" }
for_stmt = { "for" ~ identifier ~ for_mode ~ identifier ~ pacing_opt? ~ max_opt? ~ "{" ~ statement* ~ "}" }
inspect_stmt = { "inspect" ~ "(" ~ identifier ~ ")" ~ "{" ~ statement* ~ "}" }
split_map_stmt = { "split_map" ~ identifier ~ for_mode ~ identifier ~ "{" ~ statement* ~ "}" ~ "reconcile" ~ "(" ~ resolution_rules ~ ")" }

pacing_opt = { "pacing" ~ amount ~ "ms" }
max_opt = { "(" ~ "max" ~ amount ~ "ms" ~ ")" }

debug_stmt = { ("debug" | "log") ~ "(" ~ expression ~ ")" }

if_stmt = { "if" ~ "(" ~ expression ~ ")" ~ statement_block ~ ("else" ~ statement_block)? ~ reconcile_clause? }
loop_stmt = { "loop" ~ "(" ~ "max" ~ amount ~ "ms" ~ ")" ~ "{" ~ statement* ~ "}" | "loop" ~ "tick" ~ "{" ~ statement* ~ "}" }

slice_stmt = { "slice" ~ amount ~ "ms" }

network_request_stmt = { "network_request" ~ string_literal }

isolate_stmt = { "isolate" ~ identifier? ~ "{" ~ manifest ~ statement* ~ "}" }
manifest     = { (resource_decl | require_decl | slice_decl)* }
slice_decl   = { "slice" ~ amount ~ "ms" }
resource_decl = { "enable" ~ identifier ~ "(" ~ amount ~ unit? ~ ")" }
amount       = @{ ASCII_DIGIT+ }
unit         = { "ms" | "KB" | "MB" | "bytes" }

require_decl  = { "require" ~ capability_path ~ ("(" ~ param_list ~ ")")? }
capability_path = @{ identifier ~ ("." ~ identifier)* }
param_list      = { param ~ ("," ~ param)* }
param           = { (identifier | string_literal) ~ ("=" | ":") ~ expression }

split_stmt = { "split" ~ identifier ~ "into" ~ "[" ~ identifier_list ~ "]" }
merge_stmt = { "merge" ~ "[" ~ identifier_list ~ "]" ~ "into" ~ identifier ~ merge_taking_opt? ~ ("resolving" ~ "(" ~ resolution_rules ~ ")")? ~ fallback_stmt? }
merge_taking_opt = { "taking" ~ amount ~ "ms" }
identifier_list = { identifier ~ ("," ~ identifier)* }
resolution_rules = { res_rule ~ ("," ~ res_rule)* }
res_rule = { (identifier | string_literal | "_") ~ ("=" | ":") ~ resolution_strategy }
resolution_strategy = { 
    "first_wins" | 
    "decay" | 
    "auto" | 
    "priority" ~ "(" ~ identifier ~ ")" |
    topology_union | 
    topology_intersect |
    identifier
}
topology_union = { "topology_union" ~ "{" ~ resolution_rules ~ (on_invalid_clause)? ~ "}" }
topology_intersect = { "topology_intersect" ~ "{" ~ resolution_rules ~ (on_invalid_clause)? ~ "}" }
on_invalid_clause = { "on_invalid" ~ ":" ~ rewind_clause }
rewind_clause = { "rewind" ~ identifier ~ "to" ~ identifier }
reconcile_clause = { "reconcile" ~ ("auto" | "(" ~ resolution_rules ~ ")") }

anchor_stmt = { "anchor" ~ identifier }
rewind_stmt = { "rewind_to" ~ "(" ~ identifier ~ ")" }
commit_stmt = { "commit" ~ "{" ~ statement* ~ "}" }
assignment_stmt = { "let" ~ identifier ~ type_annotation? ~ "=" ~ expression }

type_annotation = { ":" ~ type_name }
type_name = { union_type }
union_type = { optional_type ~ ("|" ~ optional_type)* }
optional_type = { base_type ~ "?"? }
base_type = { identifier | "int" | "bool" | "string" | "struct" | "topology" | "array" }

open_chan_stmt = { "open_chan" ~ identifier ~ "(" ~ amount ~ ")" }
chan_send_stmt = { "chan_send" ~ identifier ~ "(" ~ identifier ~ ")" }

watchdog_stmt = { "watchdog" ~ identifier ~ "timeout" ~ amount ~ "ms" ~ ("recovery" ~ statement_block)? }

await_stmt = { "await" ~ "(" ~ identifier ~ ")" }

defer_expr = { "defer" ~ capability_path ~ "(" ~ param_list? ~ ")" ~ "deadline" ~ amount ~ "ms" }

reset_stmt = { "reset" ~ identifier ~ "to" ~ identifier }
yield_stmt = { "yield" ~ identifier }

expression = { relational_expr }
relational_expr = {
    additive_expr ~ (relop ~ additive_expr)*
}
relop = { "==" | "!=" | "<=" | ">=" | "<" | ">" }
additive_expr = { multiplicative_expr ~ (addop ~ multiplicative_expr)* }
addop = { "+" | "-" }
multiplicative_expr = { unary_expr ~ (mulop ~ unary_expr)* }
mulop = { "*" | "/" }
unary_expr = { "-" ~ unary_expr | primary_expr }
primary_expr = { base_expr ~ (index_access | field_access_tail)* }
field_access_tail = { "." ~ identifier }
field_update_stmt = { primary_expr ~ "=" ~ expression }
null = { "null" }
base_expr = { defer_expr | call_expr | chan_recv_expr | struct_lit | topology_lit | array_lit | clone_op | integer_literal | bool_literal | identifier_expr | string_literal | null | "(" ~ expression ~ ")" }
index_access = { "[" ~ expression ~ "]" }
bool_literal = { "true" | "false" }
call_expr = { "call" ~ identifier ~ "(" ~ expression_list? ~ ")" }
expression_list = { expression ~ ("," ~ expression)* }

array_lit = { "[" ~ expression ~ ("," ~ expression)* ~ "]" }

integer_literal = @{ "-"? ~ ASCII_DIGIT+ }
struct_lit = { "struct" ~ "{" ~ param_list ~ "}" }
topology_lit = { "topology" ~ "{" ~ param_list ~ "}" }
clone_op   = { "clone" ~ "(" ~ identifier ~ ")" }
field_access = { identifier ~ "." ~ identifier }
identifier_expr = { identifier }
chan_recv_expr = { "chan_recv" ~ "(" ~ identifier ~ ")" }
type_field = { identifier ~ ":" ~ type_name }
type_field_list = { type_field ~ ("," ~ type_field)* }
decay_opt = { "decay_after" ~ amount ~ "ms" }
scoped_opt = { "scoped" ~ "(" ~ "@" ~ identifier ~ ")" }
type_decl = { "type" ~ identifier ~ "=" ~ "struct" ~ decay_opt? ~ scoped_opt? ~ "{" ~ type_field_list? ~ "}" }

identifier = @{ (ASCII_ALPHA | "_") ~ (ASCII_ALPHANUMERIC | "_")* }
string_literal = @{ "\"" ~ (!"\"" ~ ANY)* ~ "\"" }
