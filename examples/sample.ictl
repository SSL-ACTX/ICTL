@0ms: {
  speculation_mode(selective)
  speculate (max 50ms) {
    let secret = "hidden"
    commit {
      let final = "committed"
    }
  } fallback {
    let final = "default"
  }
}

@60ms: {
  speculation_mode(full)
  speculate (max 50ms) {
    let secret = "hidden"
    commit {
      let final = "committed"
    }
  } fallback {
    let final = "default"
  }
}